@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<AuthorizeView>
    <Authorized>
        <MudLayout>
            <AppDrawer/>
            <MudMainContent>
                <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-6">
                    @Body
                </MudContainer>
            </MudMainContent>
        </MudLayout>
    </Authorized>
    <NotAuthorized>
        <LoginView/>
    </NotAuthorized>
</AuthorizeView>
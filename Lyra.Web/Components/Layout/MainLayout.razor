@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider Theme="LyraTheme"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<AuthorizeView>
    <Authorized>
        <MudLayout>
            <AppDrawer/>
            <MudMainContent>
                <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-6">
                    @Body
                </MudContainer>
            </MudMainContent>
        </MudLayout>
    </Authorized>
    <NotAuthorized>
        <LoginView/>
    </NotAuthorized>
</AuthorizeView>

@code
{
    MudTheme LyraTheme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = Colors.Teal.Default,
            Secondary = Colors.Indigo.Default,
        }
    };
}
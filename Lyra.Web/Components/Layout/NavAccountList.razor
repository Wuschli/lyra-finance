@using Lyra.Core.Models
@using Lyra.Core.Services
@using MudBlazor
@using Lyra.Web.Components.Dialogs
@inject AccountService AccountService
@inject EnableBankingService EnableBankingService
@inject AccountNotificationService AccountNotificationService
@inject IDialogService DialogService
@implements IAsyncDisposable

<MudNavGroup Title="Accounts" Icon="@Icons.Material.Filled.AccountBalance" Expanded="true">
    @if (_accounts == null)
    {
        <MudNavLink Disabled="true" Icon="@Icons.Material.Filled.HourglassEmpty">
            Loading...
        </MudNavLink>
    }
    else if (!_accounts.Any())
    {
        <MudNavLink Disabled="true" Icon="@Icons.Material.Outlined.Info">
            No accounts yet
        </MudNavLink>
    }
    else
    {
        @foreach (var account in _accounts)
        {
            var hasSyncFailure = _syncFailures.Contains(account.Id);
            <MudNavLink Href="@($"/accounts/{account.Id}")"
                        Icon="@Icons.Material.Filled.CreditCard">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="nav-account-row">
                    <span>@account.Name</span>
                    @if (hasSyncFailure)
                    {
                        <MudTooltip Text="Last sync failed" Placement="Placement.Right">
                            <MudIcon Icon="@Icons.Material.Filled.Error"
                                     Color="Color.Error"
                                     Size="Size.Small"
                                     Class="nav-account-sync-error"/>
                        </MudTooltip>
                    }
                    @if (account.CurrentBalance.HasValue)
                    {
                        <MudText Typo="Typo.caption"
                                 Color="@(account.CurrentBalance >= 0 ? Color.Success : Color.Error)"
                                 Class="nav-account-balance">
                            @account.CurrentBalance.Value.ToString("N2") €
                        </MudText>
                    }
                </MudStack>
            </MudNavLink>
        }
    }
    <MudNavLink Icon="@Icons.Material.Filled.Add" OnClick="OpenAddAccountDialogAsync">
        Add Account
    </MudNavLink>
</MudNavGroup>

<style>
    .nav-account-row {
        width: 100%;
    }

    .nav-account-sync-error {
        display: block;
    }

    .nav-account-balance {
        margin-right: 12px;
    }
</style>

@code {
    private List<Account>? _accounts;
    private HashSet<Guid> _syncFailures = new();

    protected override async Task OnInitializedAsync()
    {
        AccountNotificationService.OnAccountsChanged += RefreshAccountsAsync;
        await RefreshAccountsAsync();
    }

    private async Task RefreshAccountsAsync()
    {
        _accounts = (await AccountService.GetAccountsForCurrentUserAsync()).ToList();

        var logTasks = _accounts.Select(a => EnableBankingService.GetLastSyncLogByAccountIdAsync(a.Id));
        var logs = await Task.WhenAll(logTasks);

        _syncFailures = _accounts
            .Zip(logs, (account, log) => (account.Id, log))
            .Where(x => x.log != null && x.log.Status != nameof(SyncStatus.Success))
            .Select(x => x.Id)
            .ToHashSet();

        await InvokeAsync(StateHasChanged);
    }

    private async Task OpenAddAccountDialogAsync()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var parameters = new DialogParameters<AccountNameDialog>
        {
            { x => x.InitialName, string.Empty }
        };

        var dialog = await DialogService.ShowAsync<AccountNameDialog>("New Account", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: string name } && !string.IsNullOrWhiteSpace(name))
        {
            await AccountService.CreateAccountForCurrentUserAsync(name);
            await AccountNotificationService.NotifyAccountsChangedAsync();
        }
    }

    public async ValueTask DisposeAsync()
    {
        AccountNotificationService.OnAccountsChanged -= RefreshAccountsAsync;
    }

}
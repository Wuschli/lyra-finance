@using MudBlazor
@using Lyra.Core.Models
@inject IJSRuntime JS
@implements IAsyncDisposable

<div style="height: @Height; width: 100%;" class="@Class">
    <canvas id="@_canvasId"></canvas>
</div>

@code {

    /// <summary>The transactions used to reconstruct the balance history.</summary>
    [Parameter, EditorRequired]
    public IReadOnlyList<Transaction> Transactions { get; set; } = [];

    /// <summary>The current known balance to walk backwards from.</summary>
    [Parameter, EditorRequired]
    public decimal? CurrentBalance { get; set; }

    /// <summary>Number of days to display. Defaults to 30.</summary>
    [Parameter]
    public int Days { get; set; } = 30;

    /// <summary>CSS height of the chart container. Defaults to 75px.</summary>
    [Parameter]
    public string Height { get; set; } = "75px";

    /// <summary>Additional CSS classes applied to the container div.</summary>
    [Parameter]
    public string? Class { get; set; }

    private readonly string _canvasId = $"balance-chart-{Guid.NewGuid():N}";
    private bool _needsRender;
    private CancellationTokenSource? _renderCts;

    private record BalancePoint(DateTimeOffset Date, decimal Balance);

    protected override void OnParametersSet()
    {
        _needsRender = true;

        // Cancel any in-flight render triggered by the previous parameter set
        _renderCts?.Cancel();
        _renderCts?.Dispose();
        _renderCts = new CancellationTokenSource();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_needsRender)
            return;

        _needsRender = false;

        var cts = _renderCts;
        if (cts is null || cts.IsCancellationRequested)
            return;

        var token = cts.Token;

        var history = BuildBalanceHistory(Transactions, CurrentBalance, Days);

        if (token.IsCancellationRequested)
            return;

        if (history.Count > 1)
            await RenderChart(history, token);
        else
            await JS.InvokeVoidAsync("balanceChart.destroy", _canvasId, token);
    }

    private async Task RenderChart(List<BalancePoint> history, CancellationToken cancellationToken)
    {
        var labels = history
            .Select(p => p.Date.LocalDateTime.ToString("dd.MM."))
            .ToArray();

        var values = history
            .Select(p => (double)p.Balance)
            .ToArray();

        await JS.InvokeVoidAsync("balanceChart.render", cancellationToken, _canvasId, labels, values);
    }

    /// <summary>
    /// Reconstructs the per-day closing balance by walking backwards from the known
    /// current balance. The window spans from <paramref name="days"/> days ago up to
    /// the latest booked future transaction (if any). <c>CurrentBalance</c> is always
    /// the fixed anchor at the right end of the graph; future transactions are subtracted
    /// backwards just like past ones.
    /// Pending transactions are excluded.
    /// If no transactions are present but a current balance is known, a flat line
    /// at that balance is rendered across the full window.
    /// </summary>
    private static List<BalancePoint> BuildBalanceHistory(
        IReadOnlyList<Transaction> transactions,
        decimal? currentBalance,
        int days)
    {
        if (currentBalance is null)
            return [];

        var today = DateTimeOffset.UtcNow.Date;
        var startDate = today.AddDays(-(days - 1));

        if (transactions.Count == 0)
        {
            return
            [
                new BalancePoint(new DateTimeOffset(startDate, TimeSpan.Zero), currentBalance.Value),
                new BalancePoint(new DateTimeOffset(today, TimeSpan.Zero), currentBalance.Value),
            ];
        }

        // Extend the window to the latest future booked transaction date
        var maxFutureDate = transactions
            .Where(t => !t.IsPending)
            .Select(t => t.TransactionDate.LocalDateTime.Date)
            .Where(d => d > today)
            .DefaultIfEmpty(today)
            .Max();

        var dailyDeltas = transactions
            .Where(t => !t.IsPending && t.TransactionDate.LocalDateTime.Date >= startDate)
            .GroupBy(t => t.TransactionDate.LocalDateTime.Date)
            .ToDictionary(g => g.Key, g => g.Sum(t => t.Amount));

        // Walk backwards from maxFutureDate all the way to startDate.
        // CurrentBalance is the anchor at maxFutureDate (the rightmost point).
        var totalDays = (maxFutureDate - startDate).Days;
        var points = new List<BalancePoint>(totalDays + 1);
        var balance = currentBalance.Value;

        for (var i = 0; i <= totalDays; i++)
        {
            var date = maxFutureDate.AddDays(-i);
            points.Add(new BalancePoint(new DateTimeOffset(date, TimeSpan.Zero), balance));

            if (dailyDeltas.TryGetValue(date, out var delta))
                balance -= delta;
        }

        points.Reverse();
        return points;
    }

    public async ValueTask DisposeAsync()
    {
        _renderCts?.Cancel();
        _renderCts?.Dispose();
        _renderCts = null;

        await JS.InvokeVoidAsync("balanceChart.destroy", _canvasId);
    }
}
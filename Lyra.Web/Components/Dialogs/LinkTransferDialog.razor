@using Lyra.Core.Models
@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-4">
            Select the matching outgoing transaction on another account to link as an internal transfer:
        </MudText>

        @if (Candidates.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                No matching transactions found within �5 days with the opposite amount on another account.
            </MudAlert>
        }
        else
        {
            <MudRadioGroup T="Guid?" @bind-Value="_selectedId">
                @foreach (var candidate in Candidates)
                {
                    <MudRadio T="Guid?" Value="@((Guid?)candidate.Id)" Color="Color.Primary">
                        <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.body2">
                                @candidate.TransactionDate.ToLocalTime().ToString("dd.MM.yyyy")
                            </MudText>
                            <MudText Typo="Typo.body2">
                                <strong>@candidate.CounterpartyName</strong>
                            </MudText>
                            @if (!string.IsNullOrWhiteSpace(candidate.Description))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Default">@candidate.Description</MudText>
                            }
                            <MudText Typo="Typo.body2"
                                     Color="@(candidate.Amount >= 0 ? Color.Success : Color.Error)">
                                <strong>@candidate.Amount.ToString("N2") �</strong>
                            </MudText>
                        </MudStack>
                    </MudRadio>
                }
            </MudRadioGroup>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="@(_selectedId == null)"
                   OnClick="Submit">
            Link
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter, EditorRequired]
    public List<Transaction> Candidates { get; set; } = [];

    private Guid? _selectedId;

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        if (_selectedId.HasValue)
            MudDialog.Close(DialogResult.Ok(_selectedId.Value));
    }
}
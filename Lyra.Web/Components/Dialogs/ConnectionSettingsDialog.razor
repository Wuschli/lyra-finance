@using Lyra.Core.EnableBanking.Models
@using Lyra.Core.Services
@using MudBlazor
@inject EnableBankingService EnableBankingService

<MudDialog>
    <DialogContent>
        <MudSelect T="string?"
                   Label="Balance Type for Sync"
                   @bind-Value="_balanceType"
                   Clearable="true"
                   HelperText="Leave empty to disable balance sync">
            @foreach (var type in _balanceTypes)
            {
                <MudSelectItem T="string?" Value="@type">@type</MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="SaveAsync"
                   Disabled="_saving">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2"/>
            }
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter, EditorRequired]
    public Guid ConnectionId { get; set; }

    [Parameter]
    public string? BalanceType { get; set; }

    private static readonly List<string> _balanceTypes = Enum.GetNames<BalanceStatus>().ToList();

    private string? _balanceType;
    private bool _saving;

    protected override void OnParametersSet()
    {
        _balanceType = BalanceType;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        await EnableBankingService.SetBalanceTypeAsync(ConnectionId, _balanceType);
        _saving = false;
        MudDialog.Close(DialogResult.Ok(_balanceType));
    }

    private void Cancel() => MudDialog.Cancel();
}
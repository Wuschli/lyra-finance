@using Lyra.Core.Models
@using Lyra.Core.Services
@using MudBlazor
@inject EnableBankingService EnableBankingService
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudSelect T="string"
                       Label="Balance Type"
                       @bind-Value="_balanceType"
                       Clearable="true"
                       HelperText="@(_availableBalanceTypes.Count == 0 ? "Sync the connection first to see available balance types." : null)">
                @foreach (var type in _availableBalanceTypes)
                {
                    <MudSelectItem T="string" Value="@type">@type</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Guid ConnectionId { get; set; }

    [Parameter]
    public string? BalanceType { get; set; }

    [Parameter]
    public List<string> AvailableBalanceTypes { get; set; } = new();

    private string? _balanceType;
    private List<string> _availableBalanceTypes = new();

    protected override void OnParametersSet()
    {
        _balanceType = BalanceType;
        _availableBalanceTypes = AvailableBalanceTypes.Count > 0
            ? AvailableBalanceTypes
            : new();
    }

    private async Task SaveAsync()
    {
        await EnableBankingService.SetBalanceTypeAsync(ConnectionId, _balanceType);
        MudDialog.Close(DialogResult.Ok(_balanceType));
    }

    private void Cancel() => MudDialog.Cancel();
}
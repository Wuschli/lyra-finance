@page "/accounts/{AccountId:guid}"
@using Lyra.Core.Models
@using Lyra.Core.Services
@using MudBlazor
@inject AccountService AccountService
@inject NavigationManager NavManager
@attribute [Authorize]

<AppPageTitle Title="@_account?.Name"/>

@if (_account == null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary"/>
}
else
{
    <AccountDetailView Account="_account" OnBack='() => NavManager.NavigateTo("/")'/>
}

@code {
    public const string RouteTemplate = "/accounts/{0}";

    [Parameter] public Guid AccountId { get; set; }

    private Account? _account;

    protected override async Task OnParametersSetAsync()
    {
        var accounts = await AccountService.GetAccountsForCurrentUserAsync();
        _account = accounts.FirstOrDefault(a => a.Id == AccountId);
    }
}
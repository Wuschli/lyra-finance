@page "/settings/connections"
@attribute [Authorize]
@using Lyra.Core.Models
@using Lyra.Core.Services
@using MudBlazor
@using Lyra.Core.EnableBanking.Models
@using Lyra.Web.Components.Dialogs
@inject EnableBankingService EnableBankingService
@inject AccountService AccountService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject AccountNotificationService AccountNotificationService

<PageTitle>External Connections</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">External Connections</MudText>

@if (!string.IsNullOrEmpty(Error))
{
    <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="DismissError">
        @if (!string.IsNullOrEmpty(ErrorDescription))
        {
            @ErrorDescription
        }
        else
        {
            <span>Authorization failed: <strong>@Error</strong></span>
        }
    </MudAlert>
}

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Class="mb-4"/>
}
else
{
    @if (_connections.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Class="mb-4">
            No bank connections set up yet. Click <strong>Add Bank</strong> to connect your first bank.
        </MudAlert>
    }

    @foreach (var conn in _connections)
    {
        var accounts = _accountsByConnection.GetValueOrDefault(conn.Id) ?? new();
        var isSyncing = _syncingConnections.Contains(conn.Id);
        SyncLog? lastLog = _lastSyncLogs.GetValueOrDefault(conn.Id);

        <MudCard Class="mb-4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary"/>
                        <MudTextField T="string"
                                      Value="@conn.ConnectionName"
                                      ValueChanged="@(v => RenameConnectionAsync(conn, v))"
                                      Typo="Typo.h6"
                                      Variant="Variant.Text"
                                      Margin="Margin.Dense"
                                      Style="font-weight: 500"/>
                    </MudStack>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                        <MudTooltip Text="@(IsExpired(conn) ? "Session expired" : $"Valid until {conn.ExpiresAt:d}")">
                            <MudIconButton Icon="@(IsExpired(conn) ? Icons.Material.Filled.LockClock : Icons.Material.Filled.Lock)"
                                           Color="@(IsExpired(conn) ? Color.Error : Color.Success)"
                                           Size="Size.Small"
                                           DisableRipple="true"
                                           Style="cursor: default; pointer-events: none;"/>
                        </MudTooltip>
                        <MudTooltip Text="@(lastLog != null ? $"Last sync {lastLog.SyncEnd?.ToString("g") ?? lastLog.SyncStart.ToString("g")}" : "No sync yet")">
                            <MudIconButton Icon="@(lastLog != null ? GetSyncLogIcon(lastLog.Status) : Icons.Material.Outlined.Assignment)"
                                           Color="@(lastLog != null ? GetSyncLogColor(lastLog.Status) : Color.Default)"
                                           Size="Size.Small"
                                           OnClick="@(() => OpenSyncLogDialogAsync(conn.Id, conn.ConnectionName))"/>
                        </MudTooltip>
                        <MudTooltip Text="Connection settings">
                            <MudIconButton Icon="@Icons.Material.Filled.Settings"
                                           Color="Color.Default"
                                           Size="Size.Small"
                                           OnClick="@(() => OpenConnectionSettingsDialogAsync(conn))"/>
                        </MudTooltip>
                        <MudTooltip Text="Synchronize connection">
                            <MudIconButton Icon="@Icons.Material.Filled.Sync"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Disabled="@isSyncing"
                                           OnClick="@(() => SyncConnectionAsync(conn.Id))"/>
                        </MudTooltip>
                        @if (!string.IsNullOrEmpty(conn.SessionId))
                        {
                            <MudTooltip Text="Delete session (revoke bank consent)">
                                <MudIconButton Icon="@Icons.Material.Filled.LinkOff"
                                               Color="Color.Warning"
                                               Size="Size.Small"
                                               OnClick="@(() => DeleteSessionAsync(conn.Id))"/>
                            </MudTooltip>
                        }
                        <MudTooltip Text="Remove connection">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="@(() => DeleteConnectionAsync(conn.Id))"/>
                        </MudTooltip>
                    </MudStack>
                </CardHeaderActions>
            </MudCardHeader>

            @if (isSyncing)
            {
                <MudProgressLinear Indeterminate="true"/>
            }

            <MudCardContent>
                @if (accounts.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">No accounts found for this connection.</MudText>
                }
                else
                {
                    <MudTable Items="accounts" Dense="true" Hover="true" Elevation="0">
                        <ColGroup>
                            <col style="width: 20%"/>
                            <col style="width: 20%"/>
                            <col style="width: 5%"/>
                            <col style="width: 10%"/>
                            <col style="width: 45%"/>
                        </ColGroup>
                        <HeaderContent>
                            <MudTh>External Account</MudTh>
                            <MudTh>IBAN</MudTh>
                            <MudTh>Currency</MudTh>
                            <MudTh>Linked Account</MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <MudText Typo="Typo.body2">@(context.Name ?? context.Details ?? context.IdentificationHash)</MudText>
                                @if (context.Product != null)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Default">@context.Product</MudText>
                                }
                            </MudTd>
                            <MudTd>
                                <MudText Typo="Typo.body2">@(context.Iban ?? "�")</MudText>
                            </MudTd>
                            <MudTd>
                                <MudText Typo="Typo.body2">@context.Currency</MudText>
                            </MudTd>
                            <MudTd>
                                @if (context.LinkedAccountId.HasValue)
                                {
                                    var localAccount = _localAccounts.FirstOrDefault(a => a.Id == context.LinkedAccountId.Value);
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.Link"
                                             Href="@(string.Format(AccountPage.RouteTemplate, context.LinkedAccountId.Value))">
                                        @(localAccount?.Name ?? context.LinkedAccountId.Value.ToString())
                                    </MudChip>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">�</MudText>
                                }
                            </MudTd>
                            <MudTd>
                                @if (context.LinkedAccountId.HasValue)
                                {
                                    var localAccount = _localAccounts.FirstOrDefault(a => a.Id == context.LinkedAccountId.Value);
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudButton Size="Size.Small"
                                                   Variant="Variant.Outlined"
                                                   StartIcon="@Icons.Material.Filled.Edit"
                                                   Color="Color.Default"
                                                   OnClick="@(() => RenameLocalAccountAsync(context.LinkedAccountId!.Value, localAccount?.Name ?? string.Empty))">
                                            Rename Linked Account
                                        </MudButton>
                                        <MudButton Size="Size.Small"
                                                   Variant="Variant.Outlined"
                                                   StartIcon="@Icons.Material.Filled.LinkOff"
                                                   Color="Color.Error"
                                                   OnClick="@(() => UnlinkAccountAsync(context))">
                                            Unlink
                                        </MudButton>
                                    </MudStack>
                                }
                                else
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudButton Size="Size.Small"
                                                   Variant="Variant.Outlined"
                                                   StartIcon="@Icons.Material.Filled.AddCircle"
                                                   OnClick="@(() => CreateAndLinkAccountAsync(context))">
                                            New Account
                                        </MudButton>
                                        <MudButton Size="Size.Small"
                                                   Variant="Variant.Outlined"
                                                   StartIcon="@Icons.Material.Filled.Link"
                                                   OnClick="@(() => OpenLinkDialogAsync(context))">
                                            Link Existing
                                        </MudButton>
                                    </MudStack>
                                }
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudCardContent>
        </MudCard>
    }

    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="AddBankAsync">
            Add Bank
        </MudButton>
        @if (_connections.Count > 0)
        {
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.FindReplace"
                       OnClick="OpenRehashDialogAsync">
                Scan for Duplicate Transactions
            </MudButton>
        }
    </MudStack>
}

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "error_description")]
    public string? ErrorDescription { get; set; }

    [SupplyParameterFromQuery(Name = "new_connection")]
    public Guid? NewConnection { get; set; }

    private bool _loading = true;
    private List<ExternalConnection> _connections = new();

    private Dictionary<Guid, List<ExternalAccountWithLink>> _accountsByConnection = new();

    private List<Account> _localAccounts = new();

    private HashSet<Guid> _syncingConnections = new();
    private Dictionary<Guid, SyncLog> _lastSyncLogs = new();

    private static readonly List<string> _balanceTypes = Enum.GetNames<BalanceStatus>().ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();

        if (NewConnection.HasValue && _connections.Any(c => c.Id == NewConnection.Value))
        {
            NavigationManager.NavigateTo("/settings/connections", replace: true);
            _ = SyncConnectionAsync(NewConnection.Value);
        }
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        try
        {
            var connectionsTask = EnableBankingService.GetConnectionsForCurrentUserAsync();
            var localAccountsTask = AccountService.GetAccountsForCurrentUserAsync();

            await Task.WhenAll(connectionsTask, localAccountsTask);

            _connections = (await connectionsTask).ToList();
            _localAccounts = (await localAccountsTask).ToList();

            _accountsByConnection = new();
            _lastSyncLogs = new();
            foreach (var conn in _connections)
            {
                var extAccounts = await EnableBankingService.GetExternalAccountsWithLinksAsync(conn.Id);
                _accountsByConnection[conn.Id] = extAccounts.ToList();

                var lastLog = await EnableBankingService.GetLastSyncLogAsync(conn.Id);
                if (lastLog != null)
                    _lastSyncLogs[conn.Id] = lastLog;
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private static bool IsExpired(ExternalConnection conn) =>
        conn.ExpiresAt.HasValue && conn.ExpiresAt.Value < DateTimeOffset.UtcNow;

    private static Color GetSyncLogColor(string status) => status switch
    {
        nameof(SyncStatus.Success) => Color.Success,
        nameof(SyncStatus.SessionExpired) => Color.Warning,
        nameof(SyncStatus.Failure) => Color.Error,
        _ => Color.Default
    };

    private static string GetSyncLogIcon(string status) => status switch
    {
        nameof(SyncStatus.Success) => Icons.Material.Filled.CheckCircle,
        nameof(SyncStatus.SessionExpired) => Icons.Material.Filled.Warning,
        _ => Icons.Material.Filled.Error
    };

    private async Task RenameConnectionAsync(ExternalConnection conn, string newName)
    {
        if (conn.ConnectionName == newName)
            return;

        conn.ConnectionName = newName;
        await EnableBankingService.UpdateConnectionNameAsync(conn.Id, newName);
    }

    private async Task OpenConnectionSettingsDialogAsync(ExternalConnection conn)
    {
        var parameters = new DialogParameters<ConnectionSettingsDialog>
        {
            { x => x.ConnectionId, conn.Id },
            { x => x.BalanceType, conn.BalanceType },
            { x => x.AvailableBalanceTypes, conn.AvailableBalanceTypes }
        };
        var dialog = await DialogService.ShowAsync<ConnectionSettingsDialog>($"Settings � {conn.ConnectionName}", parameters);
        await dialog.Result;
    }

    private async Task SyncConnectionAsync(Guid connectionId)
    {
        _syncingConnections.Add(connectionId);
        _lastSyncLogs.Remove(connectionId);
        StateHasChanged();

        var result = await EnableBankingService.SyncExternalConnection(connectionId);

        _syncingConnections.Remove(connectionId);

        if (result.RequiresReauthorization)
        {
            NavigationManager.NavigateTo(result.ReauthorizationUrl!, forceLoad: true);
            return;
        }

        var lastLog = await EnableBankingService.GetLastSyncLogAsync(connectionId);
        if (lastLog != null)
            _lastSyncLogs[connectionId] = lastLog;

        if (result.Status == SyncStatus.Success)
            await LoadDataAsync();
        else
            StateHasChanged();
    }

    private async Task OpenSyncLogDialogAsync(Guid connectionId, string connectionName)
    {
        var parameters = new DialogParameters<SyncLogDialog>
        {
            { x => x.ConnectionId, connectionId }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true };
        await DialogService.ShowAsync<SyncLogDialog>($"Sync Logs � {connectionName}", parameters, options);
    }

    private async Task AddBankAsync()
    {
        var parameters = new DialogParameters<AddBankDialog>();
        var dialog = await DialogService.ShowAsync<AddBankDialog>("Add Bank Connection", parameters);
        var result = await dialog.Result;

        if (result.Canceled || result.Data is not (string aspspName, string aspspCountry))
            return;

        var newConnectionId = Guid.NewGuid();
        var authResult = await EnableBankingService.StartAuthorizationAsync(newConnectionId, new ASPSP { Name = aspspName, Country = aspspCountry });
        if (authResult.IsSuccess)
            NavigationManager.NavigateTo(authResult.RedirectUrl!, forceLoad: true);
    }

    private async Task DeleteConnectionAsync(Guid connectionId)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Remove Connection",
            "Are you sure you want to remove this bank connection? All linked account associations will be lost.",
            yesText: "Remove", cancelText: "Cancel");

        if (confirmed != true) return;

        await EnableBankingService.DeleteConnectionAsync(connectionId);
        await LoadDataAsync();
    }

    private async Task DeleteSessionAsync(Guid connectionId)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Session",
            "This will revoke the bank consent and clear the current session. You will need to re-authorize to sync this connection again.",
            yesText: "Delete Session", cancelText: "Cancel");

        if (confirmed != true) return;

        await EnableBankingService.DeleteSessionAsync(connectionId);
        await LoadDataAsync();
    }

    private async Task UnlinkAccountAsync(ExternalAccountWithLink extAccount)
    {
        await EnableBankingService.UnlinkExternalAccountAsync(extAccount.ExternalConnectionId, extAccount.IdentificationHash);
        await LoadDataAsync();
    }

    private async Task CreateAndLinkAccountAsync(ExternalAccountWithLink extAccount)
    {
        var suggestedName = extAccount.Name ?? extAccount.Iban ?? extAccount.IdentificationHash;

        var parameters = new DialogParameters<AccountNameDialog>
        {
            { x => x.InitialName, suggestedName }
        };
        var dialog = await DialogService.ShowAsync<AccountNameDialog>("New Account Name", parameters);
        var result = await dialog.Result;

        if (result.Canceled || result.Data is not string chosenName)
            return;

        var newAccountId = await AccountService.CreateAccountForCurrentUserAsync(chosenName);
        await EnableBankingService.LinkExternalAccountAsync(extAccount.ExternalConnectionId, extAccount.IdentificationHash, newAccountId);
        await LoadDataAsync();
        await AccountNotificationService.NotifyAccountsChangedAsync();
    }

    private async Task RenameLocalAccountAsync(Guid accountId, string currentName)
    {
        var parameters = new DialogParameters<AccountNameDialog>
        {
            { x => x.InitialName, currentName }
        };
        var dialog = await DialogService.ShowAsync<AccountNameDialog>("Rename Account", parameters);
        var result = await dialog.Result;

        if (result.Canceled || result.Data is not string newName)
            return;

        await AccountService.RenameAccountAsync(accountId, newName);
        await LoadDataAsync();
        await AccountNotificationService.NotifyAccountsChangedAsync();
    }

    private async Task OpenLinkDialogAsync(ExternalAccountWithLink extAccount)
    {
        var linkedAccountIds = _accountsByConnection.Values
            .SelectMany(accounts => accounts)
            .Where(a => a.LinkedAccountId.HasValue)
            .Select(a => a.LinkedAccountId!.Value)
            .ToHashSet();

        var unlinkedAccounts = _localAccounts
            .Where(a => !linkedAccountIds.Contains(a.Id))
            .ToList();

        var parameters = new DialogParameters<LinkAccountDialog>
        {
            { x => x.LocalAccounts, unlinkedAccounts },
            { x => x.ExternalAccount, extAccount }
        };
        var dialog = await DialogService.ShowAsync<LinkAccountDialog>("Link to Existing Account", parameters);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is Guid selectedAccountId)
        {
            await EnableBankingService.LinkExternalAccountAsync(extAccount.ExternalConnectionId, extAccount.IdentificationHash, selectedAccountId);
            await LoadDataAsync();
        }
    }

    private async Task OpenRehashDialogAsync()
    {
        var parameters = new DialogParameters<RehashTransactionsDialog>
        {
            { x => x.ConnectionIds, _connections.Select(c => c.Id).ToList() }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true };
        var dialog = await DialogService.ShowAsync<RehashTransactionsDialog>("Scan for Duplicate Transactions", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: true })
            await LoadDataAsync();
    }

    private void DismissError()
    {
        Error = null;
        ErrorDescription = null;
        NavigationManager.NavigateTo("/settings/connections", replace: true);
    }
}
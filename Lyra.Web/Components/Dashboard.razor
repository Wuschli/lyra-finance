@using Lyra.Core
@using Lyra.Core.Models
@using Lyra.Core.Services
@using MudBlazor
@inject AccountService AccountService
@inject NavigationManager NavManager
@inject EnableBankingService EnableBankingService
@inject UserService UserService
@attribute [Authorize]

<MudText Typo="Typo.h4" Class="mb-1">Financial Overview</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">Manage your accounts and transactions</MudText>

<MudGrid>
    @if (_accounts != null && _accounts.Any())
    {
        @foreach (var account in _accounts)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2" Style="cursor: pointer;" @onclick='() => NavManager.NavigateTo($"/accounts/{account.Id}")'>
                    <MudCardContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled">
                                <MudIcon Icon="@Icons.Material.Filled.AccountBalance"/>
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.h6">@account.Name</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Created @account.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")
                                </MudText>
                            </div>
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    }

    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="1" Style="border: 2px dashed var(--mud-palette-divider);">
            <MudCardContent>
                <MudText Typo="Typo.subtitle1" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Class="me-1"/>
                    New Account
                </MudText>
                <MudTextField @bind-Value="_newAccountName"
                              Label="Account Name"
                              Placeholder="e.g. Sparkasse, Crypto Wallet"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Add"
                              OnAdornmentClick="CreateAccount"
                              OnKeyUp="HandleKeyUp"
                              Immediate="true"
                              Class="mb-2"/>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Add"
                           Disabled="@string.IsNullOrWhiteSpace(_newAccountName)"
                           OnClick="CreateAccount">
                    Add Account
                </MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@if (_accounts == null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-6"/>
    <MudText Typo="Typo.body2" Class="mt-2">Loading accounts...</MudText>
}

<MudDivider Class="my-6"/>

<MudStack Row="true" Spacing="2">
    <MudButton Variant="Variant.Outlined"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Link"
               OnClick="ExternalConnectionTest">
        Connect Bank
    </MudButton>
    <MudButton Variant="Variant.Outlined"
               Color="Color.Secondary"
               StartIcon="@Icons.Material.Filled.Sync"
               Disabled="@_isSyncing"
               OnClick="SyncTest">
        @if (_isSyncing)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2"/>
            <span>Syncing...</span>
        }
        else
        {
            <span>Sync</span>
        }
    </MudButton>
</MudStack>

@code {
    private IEnumerable<Account>? _accounts;
    private string _newAccountName = string.Empty;
    private bool _isSyncing;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAccounts();
    }

    private async Task RefreshAccounts()
    {
        _accounts = await AccountService.GetAccountsForCurrentUserAsync();
    }

    private async Task CreateAccount()
    {
        if (string.IsNullOrWhiteSpace(_newAccountName)) return;

        await AccountService.CreateAccountForCurrentUserAsync(_newAccountName);
        _newAccountName = string.Empty;
        await RefreshAccounts();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await CreateAccount();
    }

    private async Task ExternalConnectionTest()
    {
        var result = await EnableBankingService.StartAuthorizationAsync(
            Guid.Parse("9588ff43-b08a-4fc0-ab5f-6fc17bd8e7bf"),
            await UserService.GetCurrentUserId());
        if (result?.Url != null)
            NavManager.NavigateTo(result.Url, true);
    }

    private async Task SyncTest()
    {
        _isSyncing = true;
        try
        {
            await EnableBankingService.SyncExternalConnection(Guid.Parse("9588ff43-b08a-4fc0-ab5f-6fc17bd8e7bf"));
        }
        finally
        {
            _isSyncing = false;
        }
    }

}
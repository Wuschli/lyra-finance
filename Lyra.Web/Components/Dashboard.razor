@using Lyra.Core
@using Lyra.Core.Models
@using Lyra.Core.Services
@inject AccountService AccountService
@inject NavigationManager NavManager
@inject EnableBankingService EnableBankingService
@inject UserService UserService
@attribute [Authorize]

<div class="container mt-4">
    @if (_selectedAccount is not null)
    {
        <AccountDetailView Account="_selectedAccount" OnBack="ClearSelection" />
    }
    else
    {
        <h3>Financial Overview</h3>

        <button @onclick="ExternalConnectionTest">External Connection Test</button>
        <button @onclick="SyncTest" disabled="@_isSyncing">
            @if (_isSyncing)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                <span>Syncing...</span>
            }
            else
            {
                <span>Sync Test</span>
            }
        </button>

        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Create New Account</h5>
                <div class="input-group">
                    <input type="text" class="form-control"
                           placeholder="Account Name (e.g. Sparkasse, Crypto Wallet)"
                           @bind="_newAccountName"
                           @onkeyup="HandleKeyUp"/>
                    <button class="btn btn-primary" @onclick="CreateAccount" disabled="@string.IsNullOrWhiteSpace(_newAccountName)">
                        Add Account
                    </button>
                </div>
            </div>
        </div>

        <h5>Your Accounts</h5>
        @if (_accounts == null)
        {
            <div class="d-flex align-items-center">
                <strong>Loading accounts...</strong>
                <div class="spinner-border ms-auto" role="status" aria-hidden="true"></div>
            </div>
        }
        else if (!_accounts.Any())
        {
            <div class="alert alert-light border">
                No accounts found. Create your first one above!
            </div>
        }
        else
        {
            <div class="list-group shadow-sm">
                @foreach (var account in _accounts)
                {
                    <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                            @onclick="() => SelectAccount(account)">
                        <div>
                            <i class="bi bi-bank me-2"></i>
                            <strong>@account.Name</strong>
                        </div>
                        <span class="text-muted small">
                            Created: @account.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        </span>
                    </button>
                }
            </div>
        }
    }
</div>

@code {
    private IEnumerable<Account>? _accounts;
    private Account? _selectedAccount;
    private string _newAccountName = string.Empty;
    private bool _isSyncing;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAccounts();
    }

    private async Task RefreshAccounts()
    {
        _accounts = await AccountService.GetAccountsForCurrentUserAsync();
    }

    private async Task CreateAccount()
    {
        if (string.IsNullOrWhiteSpace(_newAccountName)) return;

        await AccountService.CreateAccountForCurrentUserAsync(_newAccountName);

        // Reset input and refresh list
        _newAccountName = string.Empty;
        await RefreshAccounts();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await CreateAccount();
        }
    }

    private void SelectAccount(Account account)
    {
        _selectedAccount = account;
    }

    private void ClearSelection()
    {
        _selectedAccount = null;
    }

    private async Task ExternalConnectionTest()
    {
        var result = await EnableBankingService.StartAuthorizationAsync(Guid.Parse("9588ff43-b08a-4fc0-ab5f-6fc17bd8e7bf"), await UserService.GetCurrentUserId());
        if (result?.Url != null)
            NavManager.NavigateTo(result.Url, true);
    }

    private async Task SyncTest()
    {
        _isSyncing = true;
        try
        {
            await EnableBankingService.SyncExternalConnection(Guid.Parse("9588ff43-b08a-4fc0-ab5f-6fc17bd8e7bf"));
        }
        finally
        {
            _isSyncing = false;
        }
    }

}
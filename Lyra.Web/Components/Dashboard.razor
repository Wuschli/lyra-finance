@using Lyra.Core
@using Lyra.Core.Models
@using Lyra.Core.Services
@inject AccountService AccountService
@inject NavigationManager NavManager
@inject EnableBankingService EnableBankingService
@attribute [Authorize]

<div class="container mt-4">
    <h3>Financial Overview</h3>

    <button @onclick="SyncTest">Sync Test</button>

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h5 class="card-title">Create New Account</h5>
            <div class="input-group">
                <input type="text" class="form-control"
                       placeholder="Account Name (e.g. Sparkasse, Crypto Wallet)"
                       @bind="_newAccountName"
                       @onkeyup="HandleKeyUp"/>
                <button class="btn btn-primary" @onclick="CreateAccount" disabled="@string.IsNullOrWhiteSpace(_newAccountName)">
                    Add Account
                </button>
            </div>
        </div>
    </div>

    <h5>Your Accounts</h5>
    @if (_accounts == null)
    {
        <div class="d-flex align-items-center">
            <strong>Loading accounts...</strong>
            <div class="spinner-border ms-auto" role="status" aria-hidden="true"></div>
        </div>
    }
    else if (!_accounts.Any())
    {
        <div class="alert alert-light border">
            No accounts found. Create your first one above!
        </div>
    }
    else
    {
        <div class="list-group shadow-sm">
            @foreach (var account in _accounts)
            {
                <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    <div>
                        <i class="bi bi-bank me-2"></i>
                        <strong>@account.Name</strong>
                    </div>
                    <span class="text-muted small">
                        Created: @account.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                    </span>
                </div>
            }
        </div>
    }
</div>

@code {
    private IEnumerable<Account>? _accounts;
    private string _newAccountName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAccounts();
    }

    private async Task RefreshAccounts()
    {
        _accounts = await AccountService.GetAccountsForCurrentUserAsync();
    }

    private async Task CreateAccount()
    {
        if (string.IsNullOrWhiteSpace(_newAccountName)) return;

        await AccountService.CreateAccountForCurrentUserAsync(_newAccountName);

    // Reset input and refresh list
        _newAccountName = string.Empty;
        await RefreshAccounts();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await CreateAccount();
        }
    }

    private async Task SyncTest()
    {
        var result = await EnableBankingService.CreateSessionAsync();
        if (result?.Url != null)
            NavManager.NavigateTo(result.Url, true);
    }

}
@using Lyra.Core
@using Lyra.Core.Models
@using Lyra.Core.Services
@using MudBlazor
@inject AccountService AccountService
@inject NavigationManager NavManager
@inject EnableBankingService EnableBankingService
@inject UserService UserService
@inject TransactionRepository TransactionRepository
@inject IJSRuntime JS
@attribute [Authorize]
@implements IAsyncDisposable

<MudText Typo="Typo.h4" Class="mb-1">Financial Overview</MudText>
<MudText Typo="Typo.body2" Color="Color.Default" Class="mb-6">Manage your accounts and transactions</MudText>

<MudGrid>

    @* Left column: Accounts + actions (1/3) *@
    <MudItem xs="12" md="4">
        <MudGrid>
            @if (_accounts != null && _accounts.Any())
            {
                @foreach (var account in _accounts)
                {
                    var canvasId = _accountCanvasIds[account.Id];
                    var accountData = _accountData[account.Id];
                    <MudItem xs="12">
                        <MudCard Elevation="2" Style="cursor: pointer; overflow: visible;" @onclick='() => NavManager.NavigateTo($"/accounts/{account.Id}")'>
                            <MudCardContent Style="overflow: visible;">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled">
                                        <MudIcon Icon="@Icons.Material.Filled.AccountBalance"/>
                                    </MudAvatar>
                                    <div style="flex: 1; min-width: 0;">
                                        <MudText Typo="Typo.h6">@account.Name</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Default">
                                            Created @account.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")
                                        </MudText>
                                        @if (account.CurrentBalance.HasValue)
                                        {
                                            <MudText Typo="Typo.body2"
                                                     Color="@(account.CurrentBalance >= 0 ? Color.Success : Color.Error)">
                                                <strong>@account.CurrentBalance.Value.ToString("N2") €</strong>
                                            </MudText>
                                        }
                                    </div>
                                    @if (accountData.Count > 0)
                                    {
                                        <div style="width: 128px; height: 128px; flex-shrink: 0; overflow: visible;">
                                            <canvas id="@canvasId"></canvas>
                                        </div>
                                    }
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            }

            <MudItem xs="12">
                <MudCard Elevation="1" Style="border: 2px dashed var(--mud-palette-divider);">
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle1" Class="mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Add" Class="me-1"/>
                            New Account
                        </MudText>
                        <MudTextField @bind-Value="_newAccountName"
                                      Label="Account Name"
                                      Placeholder="e.g. Sparkasse, Crypto Wallet"
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@Icons.Material.Filled.Add"
                                      OnAdornmentClick="CreateAccount"
                                      OnKeyUp="HandleKeyUp"
                                      Immediate="true"
                                      Class="mb-2"/>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Disabled="@string.IsNullOrWhiteSpace(_newAccountName)"
                                   OnClick="CreateAccount">
                            Add Account
                        </MudButton>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @if (_accounts == null)
            {
                <MudItem xs="12">
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-2"/>
                    <MudText Typo="Typo.body2" Class="mt-2">Loading accounts...</MudText>
                </MudItem>
            }
        </MudGrid>

        <MudDivider Class="my-4"/>

        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.Sync"
                       Disabled="@_isSyncing"
                       OnClick="SyncTest">
                @if (_isSyncing)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2"/>
                    <span>Syncing...</span>
                }
                else
                {
                    <span>Sync</span>
                }
            </MudButton>
        </MudStack>

        @if (_syncStatus == SyncStatus.Success)
        {
            <MudAlert Severity="Severity.Success" Class="mt-4" ShowCloseIcon="true" CloseIconClicked="() => _syncStatus = null">
                Sync completed successfully.
            </MudAlert>
        }
        else if (_syncStatus == SyncStatus.Failure)
        {
            <MudAlert Severity="Severity.Error" Class="mt-4" ShowCloseIcon="true" CloseIconClicked="() => _syncStatus = null">
                Sync failed. Please check your connection and try again.
            </MudAlert>
        }
    </MudItem>
    @* Right column: Spending charts (2/3) *@
    <MudItem xs="12" md="8">
        @if (_transactions != null && _accounts != null)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                <MudText Typo="Typo.h6">Spending by Category</MudText>
                <MudText Typo="Typo.caption" Color="Color.Default">
                    Last @_periodDays days (@_periodFrom.ToString("dd.MM.yyyy") – @_periodTo.AddDays(-1).ToString("dd.MM.yyyy"))
                </MudText>
            </MudStack>

            @if (_combinedData.Count > 0)
            {
                <MudText Typo="Typo.subtitle1" Class="mb-2">All Accounts Combined</MudText>
                <MudGrid Class="mb-6">
                    <MudItem xs="12" sm="6">
                        <div style="position: relative; height: 280px;">
                            <canvas id="@_combinedCanvasId"></canvas>
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSimpleTable Dense="true" Hover="true">
                            <thead>
                            <tr>
                                <th>Category</th>
                                <th style="text-align: right;">Amount</th>
                                <th style="text-align: right;">Share</th>
                            </tr>
                            </thead>
                            <tbody>
                            @{
                                var combinedTotal = _combinedData.Sum(x => x.Value);
                            }
                            @foreach (var item in _combinedData)
                            {
                                <tr>
                                    <td>@item.Label</td>
                                    <td style="text-align: right;">@item.Value.ToString("N2") €</td>
                                    <td style="text-align: right;">@((item.Value / combinedTotal * 100).ToString("N1"))%</td>
                                </tr>
                            }
                            </tbody>
                        </MudSimpleTable>
                    </MudItem>
                </MudGrid>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-6">
                    No categorized expenses found for the selected period.
                </MudAlert>
            }
        }
        else
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-6"/>
            <MudText Typo="Typo.body2" Class="mt-2">Loading spending data...</MudText>
        }
    </MudItem>
</MudGrid>

@code {
    private IEnumerable<Account>? _accounts;
    private List<Transaction>? _transactions;
    private string _newAccountName = string.Empty;
    private bool _isSyncing;
    private SyncStatus? _syncStatus;

    private int _periodDays = 30;
    private DateTimeOffset _periodFrom;
    private DateTimeOffset _periodTo;

    private List<CategoryDataPoint> _combinedData = new();

    private Dictionary<Guid, List<CategoryDataPoint>> _accountData = new();

    private Dictionary<Guid, string> _accountCanvasIds = new();

    private readonly string _combinedCanvasId = $"pie-combined-{Guid.NewGuid():N}";

    private bool _isRendered;

    private record CategoryDataPoint(string Label, decimal Value);

    protected override async Task OnInitializedAsync()
    {
        await RefreshData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        _isRendered = true;
        await RenderAllCharts();
    }

    private async Task RenderAllCharts()
    {
        if (_combinedData.Count > 0)
            await RenderPieChart(_combinedCanvasId, _combinedData);

        foreach (var (accountId, canvasId) in _accountCanvasIds)
        {
            if (_accountData.TryGetValue(accountId, out var data) && data.Count > 0)
                await RenderCompactPieChart(canvasId, data);
        }
    }

    private async Task RenderPieChart(string canvasId, List<CategoryDataPoint> data)
    {
        var labels = data.Select(x => x.Label).ToArray();
        var values = data.Select(x => (double)x.Value).ToArray();
        await JS.InvokeVoidAsync("categoryPieChart.render", canvasId, labels, values, "Total Expenses");
    }

    private async Task RenderCompactPieChart(string canvasId, List<CategoryDataPoint> data)
    {
        var labels = data.Select(x => x.Label).ToArray();
        var values = data.Select(x => (double)x.Value).ToArray();
        await JS.InvokeVoidAsync("categoryPieChart.renderCompact", canvasId, labels, values, "Total Expenses");
    }

    private async Task RefreshData()
    {
        _periodTo = DateTimeOffset.UtcNow.Date.AddDays(1);
        _periodFrom = _periodTo.AddDays(-_periodDays);

        _accounts = (await AccountService.GetAccountsForCurrentUserAsync()).ToList();
        var userId = await UserService.GetCurrentUserId();
        _transactions = (await TransactionRepository.GetTransactionsByUserAsync(userId, _periodFrom, _periodTo)).ToList();

        _combinedData = BuildCategoryData(_transactions);

        _accountData = new();
        _accountCanvasIds = new();
        foreach (var account in _accounts)
        {
            var accountTxs = _transactions.Where(t => t.AccountId == account.Id);
            _accountData[account.Id] = BuildCategoryData(accountTxs);
            _accountCanvasIds[account.Id] = $"pie-{account.Id:N}";
        }
    }

    private async Task RefreshAccounts()
    {
        _accounts = await AccountService.GetAccountsForCurrentUserAsync();
    }

    private static List<CategoryDataPoint> BuildCategoryData(IEnumerable<Transaction> transactions)
    {
        return transactions
            .Where(t => t.Amount < 0)
            .GroupBy(t => string.IsNullOrWhiteSpace(t.Category) ? "Uncategorized" : t.Category)
            .Select(g => new CategoryDataPoint(g.Key, Math.Abs(g.Sum(t => t.Amount))))
            .OrderByDescending(x => x.Value)
            .ToList();
    }

    private async Task CreateAccount()
    {
        if (string.IsNullOrWhiteSpace(_newAccountName)) return;

        _ = await AccountService.CreateAccountForCurrentUserAsync(_newAccountName);
        _newAccountName = string.Empty;
        await RefreshData();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await CreateAccount();
    }


    private async Task SyncTest()
    {
        _isSyncing = true;
        _syncStatus = null;
        try
        {
            var connectionId = Guid.Parse("9588ff43-b08a-4fc0-ab5f-6fc17bd8e7bf");
            var status = await EnableBankingService.SyncExternalConnection(connectionId);

            if (status == SyncStatus.SessionExpired)
            {
                await EnableBankingService.ReauthorizeAsync(connectionId);
                return;
            }

            _syncStatus = status;
            await RefreshData();
        }
        finally
        {
            _isSyncing = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (!_isRendered)
            return;

        try
        {
            await JS.InvokeVoidAsync("categoryPieChart.destroy", _combinedCanvasId);
            foreach (var canvasId in _accountCanvasIds.Values)
                await JS.InvokeVoidAsync("categoryPieChart.destroy", canvasId);
        }
        catch (JSDisconnectedException)
        {
    // Circuit disconnected before disposal — JS interop is no longer available.
        }
    }

}
@using Lyra.Core.Services
@using Lyra.Web.Services
@using MudBlazor
@inject TransactionCategoryService CategoryService
@inject CategoryIconService IconService

<span class="chip @(string.IsNullOrWhiteSpace(Category) ? "empty" : "") @(OnClick.HasDelegate ? "clickable" : "")"
      style="@CategoryStyleHelper.ChipStyle(CategoryService, Category)"
      @onclick="HandleClick">
    <MudIcon Icon="@IconService.GetIcon(Category)"
             Class="icon"
             Style="@CategoryStyleHelper.IconColorStyle(CategoryService, Category)"/>
    <span class="label">@(string.IsNullOrWhiteSpace(Category) ? "Uncategorized" : Category)</span>
</span>

<style>
    .chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 14px 5px 8px;
        border-radius: 999px;
        font-size: 0.9rem;
        font-weight: 500;
        line-height: 1.4;
        white-space: nowrap;
        user-select: none;
    }

    .empty { opacity: 0.5; }

    .clickable { cursor: pointer; }

    .icon {
        font-size: 18px !important;
        width: 18px !important;
        height: 18px !important;
        flex-shrink: 0;
    }

    .label {
        overflow: hidden;
        text-overflow: ellipsis;
        color: var(--mud-palette-text-secondary);
    }
</style>

@code {
    [Parameter] public string? Category { get; set; }
    [Parameter] public EventCallback<string?> OnClick { get; set; }

    private Task HandleClick() => OnClick.HasDelegate ? OnClick.InvokeAsync(Category) : Task.CompletedTask;
}
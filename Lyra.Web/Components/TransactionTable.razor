@using Lyra.Core.Models
@using Lyra.Core.Services
@using Lyra.Web.Components.Dialogs
@using MudBlazor
@using Lyra.Core
@inject TransactionRepository TransactionRepository
@inject UserService UserService
@inject IDialogService DialogService

<style>
    /* ── Table layout ── */
    .transaction-table table {
        table-layout: fixed;
        width: 100%;
    }

    .transaction-table .cell-clip {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .transaction-table .cell-right {
        text-align: right;
        white-space: nowrap;
        text-overflow: ellipsis;
    }

    .transaction-table .cell-center {
        text-align: center;
        white-space: nowrap;
        text-overflow: ellipsis;
    }
</style>

@* Wurzelelement als Anker für ::deep *@
<div class="transaction-table">
    @* ── Toolbar ── *@
    <MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">

        <MudTextField @bind-Value="_search"
                      Placeholder="Search counterparty, IBAN, description…"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Clearable="true"
                      Immediate="true"
                      DebounceInterval="150"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense" />

        <MudDateRangePicker @bind-DateRange="_dateRange"
                            Label="Date range"
                            Variant="Variant.Outlined"
                            Margin="Margin.Dense"
                            Clearable="true"
                            DateFormat="dd.MM.yy"
                            PickerVariant="PickerVariant.Dialog"
                            RelativeWidth="DropdownWidth.Adaptive" />

        @if (ShowAccountColumn)
        {
            <MudSelect T="Guid?"
                       @bind-Value="_accountFilter"
                       Label="Account"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Clearable="true">
                @foreach (var a in Accounts)
                {
                    <MudSelectItem Value="@((Guid?)a.Id)">@a.Name</MudSelectItem>
                }
            </MudSelect>
        }

        <MudSelect T="string"
                   @bind-SelectedValues="_categoryFilter"
                   Label="Category"
                   MultiSelection="true"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Clearable="true"
                   MultiSelectionTextFunc="@(selected => selected.Count == 0 ? string.Empty : $"{selected.Count} selected")">
            <MudSelectItem Value="@((string)_uncategorizedKey)">Uncategorized</MudSelectItem>
            @foreach (var cat in _allCategories)
            {
                <MudSelectItem Value="@cat">@cat</MudSelectItem>
            }
        </MudSelect>

        <MudSelect T="AmountFilter"
                   @bind-Value="_amountFilter"
                   Label="Direction"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense">
            <MudSelectItem Value="AmountFilter.All">All</MudSelectItem>
            <MudSelectItem Value="AmountFilter.Expenses">Expenses</MudSelectItem>
            <MudSelectItem Value="AmountFilter.Income">Income</MudSelectItem>
        </MudSelect>

    </MudStack>

    @* ── Table ── *@
    <MudTable T="Transaction"
              Items="Transactions"
              Filter="_filterFunc"
              HorizontalScrollbar="false"
              Hover="true"
              Striped="true"
              Dense="true"
              Elevation="0">
        <ColGroup>
            <col style="width: 100px;"/>
            @if (ShowAccountColumn)
            {
                <col style="width: 100px;"/>
            }
            <col style="width: 18%;"/>
            <col/>
            <col style="width: 250px;"/>
            <col style="width: 115px;"/>
            <col style="width: 44px;"/>
        </ColGroup>
        <HeaderContent>
            <MudTh Class="cell-center">Date</MudTh>
            @if (ShowAccountColumn)
            {
                <MudTh Class="cell-center">Account</MudTh>
            }
            <MudTh Class="cell-center">Counterparty</MudTh>
            <MudTh Class="cell-center">Description</MudTh>
            <MudTh Class="cell-center">Category</MudTh>
            <MudTh Class="cell-center">Amount</MudTh>
            <MudTh/>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Date" Class="cell-clip">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.body2" Color="Color.Default">
                        @context.TransactionDate.ToLocalTime().ToString("dd.MM.yyyy")
                    </MudText>
                </MudStack>
            </MudTd>
            @if (ShowAccountColumn)
            {
                <MudTd DataLabel="Account" Class="cell-clip">
                    <MudText Typo="Typo.body2" Color="Color.Default">
                        @AccountName(context.AccountId)
                    </MudText>
                </MudTd>
            }
            <MudTd DataLabel="Counterparty" Class="cell-clip">
                <MudText Typo="Typo.body2" Color="Color.Default">
                    <strong>@context.CounterpartyName</strong>
                </MudText>
                @if (!string.IsNullOrWhiteSpace(context.CounterpartyIban))
                {
                    <MudText Typo="Typo.caption" Color="Color.Default">@context.CounterpartyIban</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Description" Class="cell-wrap">
                <MudText Typo="Typo.body2" Color="Color.Default">@context.Description</MudText>
            </MudTd>
            <MudTd DataLabel="Category" Class="cell-center">
                <CategoryInput Value="@context.Category"
                               SearchFunc="SearchCategoriesAsync"
                               OnCommit="@(cat => SetCategoryAsync(context, cat))"/>
            </MudTd>
            <MudTd DataLabel="Amount" Class="cell-clip cell-right">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Spacing="1">
                    @if (context.IsPending)
                    {
                        <MudTooltip Text="Pending">
                            <MudIcon Icon="@Icons.Material.Outlined.Schedule"
                                     Size="Size.Small"
                                     Color="Color.Warning"/>
                        </MudTooltip>
                    }
                    @if (context.LinkedTransactionId.HasValue)
                    {
                        <MudTooltip Text="Internal transfer">
                            <MudIcon Icon="@Icons.Material.Filled.SwapHoriz"
                                     Size="Size.Small"
                                     Color="Color.Info"/>
                        </MudTooltip>
                    }
                    <MudText Typo="Typo.body2"
                             Color="@(context.Amount >= 0 ? Color.Success : Color.Error)">
                        <strong>@context.Amount.ToString("N2") €</strong>
                    </MudText>
                </MudStack>
            </MudTd>
            <MudTd Class="cell-actions">
                @if (context.LinkedTransactionId.HasValue)
                {
                    <MudTooltip Text="Remove transfer link">
                        <MudIconButton Icon="@Icons.Material.Filled.LinkOff"
                                       Size="Size.Small"
                                       Color="Color.Default"
                                       OnClick="@(() => UnlinkAsync(context))"/>
                    </MudTooltip>
                }
                else if (context.Amount > 0 && _transferCandidateIds.Contains(context.Id))
                {
                    <MudTooltip Text="Link as internal transfer">
                        <MudIconButton Icon="@Icons.Material.Filled.Link"
                                       Size="Size.Small"
                                       Color="Color.Default"
                                       OnClick="@(() => OpenLinkDialogAsync(context))"/>
                    </MudTooltip>
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="my-2">
                No transactions match the current filter.
            </MudAlert>
        </NoRecordsContent>
    </MudTable>
</div>

@code {

    // ── Parameters ──────────────────────────────────────────────────────────

    /// <summary>The transactions to display. Filtering is applied client-side via MudTable.Filter.</summary>
    [Parameter, EditorRequired]
    public IReadOnlyList<Transaction> Transactions { get; set; } = [];

    /// <summary>
    /// Known category suggestions shared across rows. When omitted the component
    /// fetches them from the repository itself.
    /// </summary>
    [Parameter]
    public IReadOnlyList<string> AllCategories { get; set; } = [];

    /// <summary>
    /// When <c>true</c> an extra "Account" column and account filter are rendered.
    /// Pass <see cref="Accounts"/> as well so account names can be resolved.
    /// </summary>
    [Parameter]
    public bool ShowAccountColumn { get; set; }

    /// <summary>Account lookup used for the "Account" column and filter drop-down.</summary>
    [Parameter]
    public IReadOnlyList<Account> Accounts { get; set; } = [];

    /// <summary>Raised after a category has been persisted so the parent can refresh its state.</summary>
    [Parameter]
    public EventCallback<Transaction> OnCategoryChanged { get; set; }

    /// <summary>Raised after a transfer link has been created or removed.</summary>
    [Parameter]
    public EventCallback OnTransferLinkChanged { get; set; }

    /// <summary>Pre-selects the category filter on first render. Supplied via query string.</summary>
    [Parameter]
    public string? InitialCategory { get; set; }

    // ── State ────────────────────────────────────────────────────────────────

    // Sentinel key used to represent "no category assigned" in the filter list.
    private const string _uncategorizedKey = "__uncategorized__";

    private string? _search;
    private AmountFilter _amountFilter = AmountFilter.All;
    private Guid? _accountFilter;
    private IReadOnlyCollection<string> _categoryFilter = new List<string>();
    private DateRange? _dateRange;
    private List<string> _allCategories = new();

    private bool _initialCategoryApplied;

    /// <summary>
    /// IDs of unlinked income transactions that have at least one transfer candidate in the DB.
    /// Used to gate visibility of the link button without a per-row DB call.
    /// </summary>
    private HashSet<Guid> _transferCandidateIds = [];

    // ── Lifecycle ────────────────────────────────────────────────────────────

    protected override async Task OnParametersSetAsync()
    {
        if (AllCategories.Count > 0)
            _allCategories = AllCategories.ToList();

        if (!_initialCategoryApplied && !string.IsNullOrWhiteSpace(InitialCategory))
        {
            var filterValue = InitialCategory.Equals("Uncategorized", StringComparison.OrdinalIgnoreCase)
                ? _uncategorizedKey
                : InitialCategory;

            _categoryFilter = new List<string> { filterValue };
            _initialCategoryApplied = true;
        }

        await RefreshCandidateIdsAsync();
    }

    // ── Filter delegate ──────────────────────────────────────────────────────

    private bool _filterFunc(Transaction t)
    {
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var term = _search.Trim();
            if (!Contains(t.CounterpartyName, term) &&
                !Contains(t.CounterpartyIban, term) &&
                !Contains(t.Description, term) &&
                !Contains(t.Category, term))
                return false;
        }

        if (_amountFilter == AmountFilter.Expenses && t.Amount >= 0) return false;
        if (_amountFilter == AmountFilter.Income   && t.Amount <  0) return false;

        if (_accountFilter.HasValue && t.AccountId != _accountFilter.Value) return false;

        var selectedCategories = _categoryFilter.ToList();
        if (selectedCategories.Count > 0)
        {
            var includeUncategorized = selectedCategories.Contains(_uncategorizedKey);
            var namedCategories = selectedCategories
                .Where(c => c != _uncategorizedKey)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            var isUncategorized = string.IsNullOrWhiteSpace(t.Category);
            if (isUncategorized && !includeUncategorized) return false;
            if (!isUncategorized && !namedCategories.Contains(t.Category!)) return false;
        }

        if (_dateRange?.Start is not null &&
            t.TransactionDate.LocalDateTime.Date < _dateRange.Start.Value.Date) return false;

        if (_dateRange?.End is not null &&
            t.TransactionDate.LocalDateTime.Date > _dateRange.End.Value.Date) return false;

        return true;
    }

    private static bool Contains(string? haystack, string needle)
        => haystack?.Contains(needle, StringComparison.OrdinalIgnoreCase) ?? false;

    // ── Helpers ──────────────────────────────────────────────────────────────

    private string AccountName(Guid accountId)
        => Accounts.FirstOrDefault(a => a.Id == accountId)?.Name ?? accountId.ToString("N")[..8];

    private Task<IEnumerable<string>> SearchCategoriesAsync(string? text, CancellationToken _)
    {
        var results = string.IsNullOrWhiteSpace(text)
            ? (IEnumerable<string>)_allCategories
            : _allCategories.Where(s => s.Contains(text, StringComparison.OrdinalIgnoreCase));

        return Task.FromResult(results);
    }

    private async Task RefreshCandidateIdsAsync()
    {
        var userId = await UserService.GetCurrentUserId();

        var incomeTransactions = Transactions
            .Where(t => t.Amount > 0 && t.LinkedTransactionId == null)
            .ToList();

        _transferCandidateIds = await TransactionRepository.FindTransferCandidateSourceIdsAsync(
            userId, incomeTransactions);
    }

    // ── Actions ──────────────────────────────────────────────────────────────

    private async Task SetCategoryAsync(Transaction tx, string? category)
    {
        await TransactionRepository.SetCategoryAsync(tx.Id, category);
        tx.Category = category;

        var userId = await UserService.GetCurrentUserId();
        _allCategories = (await TransactionRepository.GetDistinctCategoriesAsync(userId)).ToList();

        await OnCategoryChanged.InvokeAsync(tx);
    }

    private async Task OpenLinkDialogAsync(Transaction tx)
    {
        var userId = await UserService.GetCurrentUserId();
        var candidates = (await TransactionRepository.FindTransferCandidatesAsync(
            userId, tx.Id, tx.Amount, tx.TransactionDate)).ToList();

        var parameters = new DialogParameters<LinkTransferDialog>
        {
            { x => x.Candidates, candidates }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<LinkTransferDialog>("Link internal transfer", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: Guid partnerId })
        {
            await TransactionRepository.LinkTransactionsAsync(tx.Id, partnerId);
            tx.LinkedTransactionId = partnerId;
            _transferCandidateIds.Remove(tx.Id);

            var partner = Transactions.FirstOrDefault(t => t.Id == partnerId);
            if (partner is not null)
            {
                partner.LinkedTransactionId = tx.Id;
                _transferCandidateIds.Remove(partnerId);
            }

            await OnTransferLinkChanged.InvokeAsync();
        }
    }

    private async Task UnlinkAsync(Transaction tx)
    {
        await TransactionRepository.UnlinkTransactionAsync(tx.Id);

        var partnerId = tx.LinkedTransactionId;
        tx.LinkedTransactionId = null;

        if (partnerId.HasValue)
        {
            var partner = Transactions.FirstOrDefault(t => t.Id == partnerId.Value);
            if (partner is not null)
                partner.LinkedTransactionId = null;
        }

        // Re-evaluate candidate visibility after unlinking
        await RefreshCandidateIdsAsync();
        await OnTransferLinkChanged.InvokeAsync();
    }

    // ── Nested types ─────────────────────────────────────────────────────────

    private enum AmountFilter { All, Expenses, Income }
}
@using Lyra.Core.Services
@using Lyra.Web.Services
@using MudBlazor
@inject TransactionCategoryService CategoryService
@inject CategoryIconService IconService
@inject IJSRuntime JS

<div class="@RootClass">
    <div class="field" @onclick="ToggleAsync">
        @if (!_open)
        {
            @* Show selected value or placeholder chip when closed *@
            <span class="@(_hasValue ? "chip" : "chip placeholder")">
                <CategoryChip Category="@(_hasValue ? Value : null)"/>
            </span>
        }
        <input @ref="_inputRef"
               type="text"
               class="native @(!_open ? "hidden" : "")"
               value="@_inputText"
               autocomplete="off"
               placeholder="Search…"
               @oninput="OnInput"
               @onkeydown="OnKeyDown"
               @onfocus="OnFocus"
               @onblur="OnBlur"/>
        @if (_open)
        {
            <button type="button" class="clear" tabindex="-1"
                    @onmousedown:preventDefault
                    @onclick:stopPropagation
                    @onclick="ClearAsync">
                <MudIcon Icon="@Icons.Material.Filled.Close" Class="clear-icon"/>
            </button>
        }
    </div>

    @if (_open && _suggestions.Any())
    {
        <div class="popover" id="@_popoverId">
            @for (var i = 0; i < _suggestions.Count; i++)
            {
                var item = _suggestions[i];
                var index = i;
                var isSelected = item == Value;
                var isHighlighted = index == _highlightedIndex;
                <div class="option @(isSelected ? "selected" : "") @(isHighlighted ? "highlighted" : "")"
                     data-index="@index"
                     @onpointerdown:preventDefault
                     @onmouseover="() => _highlightedIndex = index"
                     @onclick="() => SelectAsync(item)">
                    @if (isSelected)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Check" Class="check-icon"/>
                    }
                    else
                    {
                        <span class="check-placeholder"></span>
                    }
                    <CategoryChip Category="@item"/>
                </div>
            }
        </div>
    }
</div>

<script>
    (function () {
        document.addEventListener('keydown', function (e) {
            if ((e.key === 'ArrowDown' || e.key === 'ArrowUp') &&
                e.target.classList.contains('native')) {
                e.preventDefault();
            }
        }, true);
    })();

    window.catInputScrollHighlighted = function (popoverId, index) {
        const popover = document.getElementById(popoverId);
        if (!popover) return;
        const item = popover.querySelector('[data-index="' + index + '"]');
        if (!item) return;
        item.scrollIntoView({ block: 'nearest' });
    };
</script>

<style>
    .root {
        position: relative;
        width: 100%;
        font-family: inherit;
    }

    .field {
        display: flex;
        align-items: center;
        gap: 6px;
        position: relative;
        border: 1px solid rgba(var(--mud-palette-text-primary), 0.23);
        border-radius: 4px;
        padding: 4px 8px;
        cursor: pointer;
        transition: border-color 0.2s;
        background: transparent;
        min-height: 44px;
        box-sizing: border-box;
    }

    .focused .field {
        border: 2px solid var(--mud-palette-primary);
        padding: 3px 7px;
    }

    .focused .field:hover { border-color: var(--mud-palette-primary); }

    .field:hover { border-color: rgba(var(--mud-palette-text-primary), 0.6); }

    .placeholder { opacity: 0.5; }

    /* ── Native input ── */

    .native {
        flex: 1;
        border: none;
        outline: none;
        background: transparent;
        font-size: 0.875rem;
        color: var(--mud-palette-text-primary);
        min-width: 0;
        padding: 2px 0;
        cursor: pointer;
        caret-color: var(--mud-palette-primary);
    }

    .hidden { display: none; }

    .native::placeholder { color: rgba(var(--mud-palette-text-secondary), 0.5); }

    /* ── Popover ── */

    .popover {
        position: absolute;
        z-index: 1300;
        left: 0;
        right: 0;
        min-width: max-content;
        top: calc(100% + 2px);
        background: var(--mud-palette-surface);
        border-radius: 4px;
        box-shadow: 0 5px 5px -3px rgba(0,0,0,.2),
                    0 8px 10px 1px rgba(0,0,0,.14),
                    0 3px 14px 2px rgba(0,0,0,.12);
        max-height: 280px;
        overflow-x: hidden;
        overflow-y: auto;
    }

    /* ── Option row ── */

    .option {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 7px 12px;
        font-size: 0.875rem;
        cursor: pointer;
        transition: background 0.15s;
        color: var(--mud-palette-text-primary);
    }

    .option:hover    { background: rgba(var(--mud-palette-primary-rgb), 0.08); }
    .selected        { background: rgba(var(--mud-palette-primary-rgb), 0.06); }
    .selected:hover  { background: rgba(var(--mud-palette-primary-rgb), 0.12); }
    .highlighted     { background: rgba(var(--mud-palette-primary-rgb), 0.14); }

    /* ── Check icon ── */

    .check-icon {
        font-size: 18px !important;
        width: 18px !important;
        height: 18px !important;
        color: var(--mud-palette-primary);
        flex-shrink: 0;
    }

    .check-placeholder {
        display: inline-block;
        width: 18px;
        height: 18px;
        flex-shrink: 0;
    }

    /* ── Clear button ── */

    .clear {
        display: flex;
        align-items: center;
        background: none;
        border: none;
        padding: 2px;
        cursor: pointer;
        color: rgba(var(--mud-palette-text-secondary), 0.7);
        flex-shrink: 0;
        border-radius: 50%;
        transition: color 0.15s, background 0.15s;
    }

    .clear:hover {
        color: var(--mud-palette-text-primary);
        background: rgba(var(--mud-palette-text-primary), 0.08);
    }

    .clear-icon {
        font-size: 18px !important;
        width: 18px !important;
        height: 18px !important;
    }
</style>

@code {

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public Func<string?, CancellationToken, Task<IEnumerable<string>>> SearchFunc { get; set; }
        = (_, _) => Task.FromResult(Enumerable.Empty<string>());

    [Parameter]
    public EventCallback<string?> OnCommit { get; set; }

    private ElementReference _inputRef;
    private string? _inputText;
    private bool _open;
    private bool _focused;
    private bool _focusInputOnRender;
    private int _highlightedIndex = -1;
    private bool _scrollHighlightedOnRender;
    private List<string> _suggestions = [];

    private readonly string _popoverId = $"cat-popover-{Guid.NewGuid():N}";

    private bool _hasValue => !string.IsNullOrEmpty(Value);

    private string RootClass
    {
        get
        {
            var cls = "root";
            if (_open)     cls += " open";
            if (_focused)  cls += " focused";
            if (_hasValue) cls += " has-value";
            return cls;
        }
    }

    // ── Lifecycle ────────────────────────────────────────────────────────────

    protected override void OnParametersSet()
    {
        if (!_focused)
            _inputText = Value;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusInputOnRender)
        {
            _focusInputOnRender = false;
            await _inputRef.FocusAsync();
        }

        if (_scrollHighlightedOnRender && _highlightedIndex >= 0)
        {
            _scrollHighlightedOnRender = false;
            await JS.InvokeVoidAsync("catInputScrollHighlighted", _popoverId, _highlightedIndex);
        }
    }

    // ── Input events ─────────────────────────────────────────────────────────

    private async Task OnInput(ChangeEventArgs e)
    {
        _inputText = e.Value?.ToString();
        _highlightedIndex = -1;
        await RefreshSuggestionsAsync(_inputText);
        _open = _suggestions.Any();
    }

    private void OnFocus()
    {
        _focused = true;
        _inputText = Value;
    }

    private async Task OnBlur()
    {
        _focused = false;
        _open = false;
        _highlightedIndex = -1;
        await CommitCurrentInputAsync();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "ArrowDown":
                if (!_open)
                {
                    await OpenAsync();
                    _highlightedIndex = 0;
                }
                else if (_suggestions.Any())
                {
                    _highlightedIndex = Math.Min(_highlightedIndex + 1, _suggestions.Count - 1);
                }
                _scrollHighlightedOnRender = true;
                break;

            case "ArrowUp":
                if (_open && _suggestions.Any())
                {
                    _highlightedIndex = Math.Max(_highlightedIndex - 1, 0);
                    _scrollHighlightedOnRender = true;
                }
                break;

            case "Enter":
                if (_open && _highlightedIndex >= 0 && _highlightedIndex < _suggestions.Count)
                    await SelectAsync(_suggestions[_highlightedIndex]);
                else
                {
                    _open = false;
                    await CommitCurrentInputAsync();
                }
                break;

            case "Escape":
                _open = false;
                _highlightedIndex = -1;
                _inputText = Value;
                break;
        }
    }

    // ── Dropdown ─────────────────────────────────────────────────────────────

    private async Task ToggleAsync()
    {
        if (_open)
        {
            _open = false;
            _highlightedIndex = -1;
        }
        else
        {
            await OpenAsync();
        }
    }

    private async Task OpenAsync()
    {
        await RefreshSuggestionsAsync(_inputText);
        if (_suggestions.Any())
        {
            _open = true;
            _highlightedIndex = -1;
            _focusInputOnRender = true;
        }
    }

    private async Task SelectAsync(string item)
    {
        _inputText = item;
        _open = false;
        _highlightedIndex = -1;
        await CommitAsync(item);
    }

    private async Task ClearAsync()
    {
        _inputText = null;
        _open = false;
        _highlightedIndex = -1;
        await CommitAsync(null);
    }

    // ── Helpers ──────────────────────────────────────────────────────────────

    private async Task RefreshSuggestionsAsync(string? text)
        => _suggestions = (await SearchFunc(text, CancellationToken.None)).ToList();

    private Task CommitCurrentInputAsync()
        => CommitAsync(string.IsNullOrWhiteSpace(_inputText) ? null : _inputText!.Trim());

    private async Task CommitAsync(string? value)
    {
        var normalized = string.IsNullOrWhiteSpace(value) ? null : value.Trim();
        if (normalized != Value)
            await OnCommit.InvokeAsync(normalized);
    }

}
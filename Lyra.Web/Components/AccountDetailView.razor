@using Lyra.Core
@using Lyra.Core.EnableBanking.Models
@using Lyra.Core.Models
@using Lyra.Core.Services
@using MudBlazor
@using Transaction = Lyra.Core.Models.Transaction
@inject TransactionRepository TransactionRepository
@inject UserService UserService
@inject EnableBankingService EnableBankingService

<MudText Typo="Typo.h4" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Class="me-2 mb-1"/>@Account.Name
</MudText>

@if (Account.CurrentBalance.HasValue)
{
    <MudText Typo="Typo.body1" Color="@(Account.CurrentBalance >= 0 ? Color.Success : Color.Error)" Class="mb-1">
        <strong>@Account.CurrentBalance.Value.ToString("N2") Ć</strong>
    </MudText>
    @if (Account.CurrentBalanceAt.HasValue)
    {
        <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-1">
            Stand: @Account.CurrentBalanceAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
        </MudText>
    }
}

<MudText Typo="Typo.body2" Color="Color.Default" Class="mb-4">Transactions for this account</MudText>

@if (_externalConnection != null)
{
    <MudButton Variant="Variant.Text"
               StartIcon="@Icons.Material.Filled.Sync"
               EndIcon="@(_syncSettingsExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
               OnClick="() => _syncSettingsExpanded = !_syncSettingsExpanded"
               Class="mb-2">
        Sync-Settings
    </MudButton>
    <MudCollapse Expanded="_syncSettingsExpanded">
        <MudPaper Class="pa-4 mb-6" Elevation="1">
            <MudSelect T="string?"
                       Label="Balance-Typ f³r Sync"
                       Value="_selectedBalanceType"
                       ValueChanged="OnBalanceTypeChanged"
                       Clearable="
                    true"
                       HelperText="Leer lassen um Saldo-Sync zu deaktivieren">
                @foreach (var type in _balanceTypes)
                {
                    <MudSelectItem T="string?" Value="@type">@type</MudSelectItem>
                }
            </MudSelect>
        </MudPaper>
    </MudCollapse>
}

@if (_transactions == null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-4"/>
    <MudText Typo="Typo.body2" Class="mt-2">Loading transactions...</MudText>
}
else if (!_transactions.Any())
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">
        No transactions found for this account.
    </MudAlert>
}
else
{
    <MudTable Items="_transactions"
              Hover="true"
              Striped="true"
              Dense="true"
              Elevation="2"
              Class="rounded">
        <HeaderContent>
            <MudTh Style="width: 110px;">Date</MudTh>
            <MudTh>Counterparty</MudTh>
            <MudTh>Description</MudTh>
            <MudTh Style="width: 130px; text-align: right;">Amount</MudTh>
            <MudTh Style="min-width: 200px;">Category</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Date">
                <MudText Typo="Typo.body2" Color="Color.Default">
                    @context.TransactionDate.ToLocalTime().ToString("dd.MM.yyyy")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Counterparty">
                <MudText Typo="Typo.body2" Color="Color.Default">
                    <strong>@context.CounterpartyName</strong>
                </MudText>
                @if (!string.IsNullOrWhiteSpace(context.CounterpartyIban))
                {
                    <MudText Typo="Typo.caption" Color="Color.Default">@context.CounterpartyIban</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Description">
                <MudText Typo="Typo.body2" Color="Color.Default">@context.Description</MudText>
            </MudTd>
            <MudTd DataLabel="Amount" Style="text-align: right;">
                <MudText Typo="Typo.body2"
                         Color="@(context.Amount >= 0 ? Color.Success : Color.Error)">
                    <strong>@context.Amount.ToString("N2") Ć</strong>
                </MudText>
            </MudTd>
            <MudTd DataLabel="Category">
                <CategoryInput
                    Value="@context.Category"
                    Suggestions="_allCategories"
                    OnCommit="@(cat => SetCategory(context, cat))"/>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {

    [Parameter, EditorRequired]
    public Account Account { get; set; } = null!;

    [Parameter]
    public EventCallback OnBack { get; set; }

    private List<Transaction>? _transactions;
    private List<string> _allCategories = [];

    private ExternalConnection? _externalConnection;
    private string? _selectedBalanceType;
    private bool _syncSettingsExpanded;

    private static readonly List<string> _balanceTypes = Enum.GetNames<BalanceStatus>().ToList();

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var userId = await UserService.GetCurrentUserId();
        _transactions = (await TransactionRepository.GetTransactionsByAccountAsync(Account.Id)).ToList();
        _allCategories = (await TransactionRepository.GetDistinctCategoriesAsync(userId)).ToList();
        _externalConnection = await EnableBankingService.GetExternalConnectionByAccountIdAsync(Account.Id);
        _selectedBalanceType = _externalConnection?.BalanceType;
    }

    private async Task OnBalanceTypeChanged(string? value)
    {
        _selectedBalanceType = value;
        if (_externalConnection != null)
        {
            await EnableBankingService.SetBalanceTypeAsync(_externalConnection.Id, value);
            _externalConnection.BalanceType = value;
        }
    }

    private async Task SetCategory(Transaction tx, string? category)
    {
        await TransactionRepository.SetCategoryAsync(tx.Id, category);
        tx.Category = category;

    // Refresh suggestions if a new category was introduced
        var userId = await UserService.GetCurrentUserId();
        _allCategories = (await TransactionRepository.GetDistinctCategoriesAsync(userId)).ToList();
    }

}
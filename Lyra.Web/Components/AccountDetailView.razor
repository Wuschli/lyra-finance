@using Lyra.Core
@using Lyra.Core.Models
@using Lyra.Core.Services
@inject TransactionRepository TransactionRepository
@inject UserService UserService

<div class="mt-3">
    <div class="d-flex align-items-center mb-3">
        <button class="btn btn-outline-secondary btn-sm me-3" @onclick="OnBack">
            <i class="bi bi-arrow-left me-1"></i>Back
        </button>
        <h4 class="mb-0">
            <i class="bi bi-bank me-2"></i>@Account.Name
        </h4>
    </div>

    @if (_transactions == null)
    {
        <div class="d-flex align-items-center">
            <strong>Loading transactions...</strong>
            <div class="spinner-border ms-auto" role="status" aria-hidden="true"></div>
        </div>
    }
    else if (!_transactions.Any())
    {
        <div class="alert alert-light border">
            No transactions found for this account.
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Counterparty</th>
                        <th>Description</th>
                        <th class="text-end">Amount</th>
                        <th style="min-width: 200px;">Category</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tx in _transactions)
                    {
                        <tr>
                            <td class="text-nowrap text-muted small">
                                @tx.TransactionDate.ToLocalTime().ToString("dd.MM.yyyy")
                            </td>
                            <td>
                                <div><strong>@tx.CounterpartyName</strong></div>
                                @if (!string.IsNullOrWhiteSpace(tx.CounterpartyIban))
                                {
                                    <div class="text-muted small">@tx.CounterpartyIban</div>
                                }
                            </td>
                            <td class="text-muted small">@tx.Description</td>
                            <td class="text-end text-nowrap @(tx.Amount >= 0 ? "text-success" : "text-danger")">
                                <strong>@tx.Amount.ToString("N2") €</strong>
                            </td>
                            <td>
                                <CategoryInput
                                    Value="@tx.Category"
                                    Suggestions="_allCategories"
                                    OnCommit="@(cat => SetCategory(tx, cat))" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public Account Account { get; set; } = null!;
    [Parameter] public EventCallback OnBack { get; set; }

    private List<Transaction>? _transactions;
    private List<string> _allCategories = [];

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var userId = await UserService.GetCurrentUserId();
        _transactions = (await TransactionRepository.GetTransactionsByAccountAsync(Account.Id)).ToList();
        _allCategories = (await TransactionRepository.GetDistinctCategoriesAsync(userId)).ToList();
    }

    private async Task SetCategory(Transaction tx, string? category)
    {
        await TransactionRepository.SetCategoryAsync(tx.Id, category);
        tx.Category = category;

        // Refresh suggestions if a new category was introduced
        var userId = await UserService.GetCurrentUserId();
        _allCategories = (await TransactionRepository.GetDistinctCategoriesAsync(userId)).ToList();
    }
}
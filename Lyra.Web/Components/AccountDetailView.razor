@using Lyra.Core
@using Lyra.Core.EnableBanking.Models
@using Lyra.Core.Models
@using Lyra.Core.Services
@using Lyra.Web.Components.Dialogs
@using MudBlazor
@using Transaction = Lyra.Core.Models.Transaction
@inject TransactionRepository TransactionRepository
@inject UserService UserService
@inject EnableBankingService EnableBankingService
@inject IDialogService DialogService
@inject AccountService AccountService
@inject AccountNotificationService AccountNotificationService
@implements IAsyncDisposable

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-1">
    <MudText Typo="Typo.h4">
        <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Class="me-2 mb-1"/>@Account.Name
    </MudText>
    <MudButton Variant="Variant.Outlined"
               StartIcon="@Icons.Material.Filled.UploadFile"
               Color="Color.Primary"
               Size="Size.Small"
               OnClick="OpenImportDialog">
        Import CSV
    </MudButton>
</MudStack>

@if (Account.CurrentBalance.HasValue)
{
    <MudText Typo="Typo.body1" Color="@(Account.CurrentBalance >= 0 ? Color.Success : Color.Error)" Class="mb-1">
        <strong>@Account.CurrentBalance.Value.ToString("N2") €</strong>
    </MudText>
    @if (Account.CurrentBalanceAt.HasValue)
    {
        <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-1">
            Stand: @Account.CurrentBalanceAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
        </MudText>
    }
}

@if (_transactions == null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-4"/>
    <MudText Typo="Typo.body2" Class="mt-2">Loading transactions...</MudText>
}
else
{
    <BalanceChart Transactions="_transactions"
                  CurrentBalance="Account.CurrentBalance"
                  Class="mb-2"/>

    <TransactionTable
        Transactions="_transactions"
        AllCategories="_allCategories"
        OnCategoryChanged="OnCategoryChanged"/>
}

@code {

    [Parameter, EditorRequired]
    public Account Account { get; set; } = null!;

    [Parameter]
    public EventCallback OnBack { get; set; }

    private List<Transaction>? _transactions;
    private List<string> _allCategories = new();

    protected override async Task OnInitializedAsync()
    {
        AccountNotificationService.OnAccountsChanged += OnAccountsChangedAsync;
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
    }

    private async Task OnAccountsChangedAsync()
    {
        var accounts = (await AccountService.GetAccountsForCurrentUserAsync()).ToList();
        var updated = accounts.FirstOrDefault(a => a.Id == Account.Id);
        if (updated != null)
            Account = updated;

        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadData()
    {
        var userId = await UserService.GetCurrentUserId();
        _transactions = (await TransactionRepository.GetTransactionsByAccountAsync(Account.Id)).ToList();
        _allCategories = (await TransactionRepository.GetDistinctCategoriesAsync(userId)).ToList();
    }

    private async Task OnCategoryChanged(Transaction tx)
    {
        var userId = await UserService.GetCurrentUserId();
        _allCategories = (await TransactionRepository.GetDistinctCategoriesAsync(userId)).ToList();
    }

    private async Task OpenImportDialog()
    {
        var parameters = new DialogParameters<ImportCsvDialog>
        {
            { x => x.AccountId, Account.Id }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ImportCsvDialog>("Import CSV transactions", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
            await LoadData();
    }

    public async ValueTask DisposeAsync()
    {
        AccountNotificationService.OnAccountsChanged -= OnAccountsChangedAsync;
    }
}